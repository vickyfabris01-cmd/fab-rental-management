# =============================================================================
# fab-rental-management — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is in .gitignore.
#
# All VITE_* variables are embedded into the browser bundle at build time.
# Non-VITE_* variables are only available server-side (FastAPI / scripts).
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# Supabase (required)
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# Your project's REST + Auth base URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon (public) key — safe to expose; RLS protects all tables
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose in frontend; backend use only
# Used by FastAPI to bypass RLS for admin operations
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ─────────────────────────────────────────────────────────────────────────────
# FastAPI Backend
# ─────────────────────────────────────────────────────────────────────────────

# Base URL the React app uses to call the backend
# Development: http://localhost:8000
# Production:  https://api.fabrentals.co.ke
VITE_API_BASE_URL=http://localhost:8000

# Secret key for signing internal tokens (generate with: openssl rand -hex 32)
SECRET_KEY=replace_with_a_long_random_string_minimum_32_chars

# Allowed CORS origins (comma-separated, no trailing slash)
BACKEND_CORS_ORIGINS=http://localhost:5173,https://fabrentals.co.ke


# ─────────────────────────────────────────────────────────────────────────────
# M-Pesa (Safaricom Daraja API)
# Sandbox: https://developer.safaricom.co.ke
# ─────────────────────────────────────────────────────────────────────────────

# Paybill or Till number shown to customers
VITE_MPESA_PAYBILL=174379
VITE_MPESA_SHORTCODE=174379

# Daraja API credentials (backend only — never expose in frontend)
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_PASSKEY=your_lipa_na_mpesa_passkey

# Environment: sandbox | production
MPESA_ENV=sandbox

# Callback URL Safaricom will POST payment confirmations to
# Must be publicly reachable (use ngrok in dev)
MPESA_CALLBACK_URL=https://your-domain.co.ke/payments/mpesa/callback


# ─────────────────────────────────────────────────────────────────────────────
# SMS Gateway (e.g. Africa's Talking, Twilio)
# ─────────────────────────────────────────────────────────────────────────────

# Provider: africastalking | twilio | vonage
SMS_PROVIDER=africastalking

# Africa's Talking
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=fabRentals

# Twilio (fill if using Twilio instead)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=


# ─────────────────────────────────────────────────────────────────────────────
# Email (SMTP or SendGrid)
# ─────────────────────────────────────────────────────────────────────────────

# Provider: smtp | sendgrid
EMAIL_PROVIDER=sendgrid

# SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM_ADDRESS=noreply@fabrentals.co.ke
EMAIL_FROM_NAME=fabRentals

# SMTP fallback (fill if using SMTP instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true


# ─────────────────────────────────────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────────────────────────────────────

# Set to "production" in prod — enables stricter error handling
NODE_ENV=development

# App public URL (used for invite / reset links in emails)
VITE_APP_URL=http://localhost:5173
